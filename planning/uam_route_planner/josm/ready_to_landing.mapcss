canvas {
    fill-color: #0000f;
    text-color: #ffffff;
    error-color: #ffffff;
}

node[!ready_to_landing],
node[ready_to_landing != 0] {
    symbol-shape: square;
    symbol-stroke-width:1.0;
    symbol-fill-color: #00ff00;
    symbol-stroke-color: #ffffff;
    text: eval("Flight to hovering mode switching");
    font-size: 30;
    text-offset: 5;
}
