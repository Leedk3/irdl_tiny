canvas {
    fill-color: #0000f;
    text-color: #ffffff;
    error-color: #ffffff;
}

node[!state_steer],
node[state_steer != 0] {
    symbol-shape: square;
    symbol-stroke-width: 1.0;
    symbol-fill-color: #ffff00;
    symbol-stroke-color: #ffffff;
    text: eval(tag("state_steer"));
    font-size: 12;
    text-offset: 5;
}
