canvas {
    fill-color: #0000f;
    text-color: #ffffff;
    error-color: #ffffff;
}

node[!imu_acc_x],
node[imu_acc_x != 0] {
    symbol-shape: square;
    symbol-stroke-width: 1.0;
    symbol-fill-color: #ff0000;
    symbol-stroke-color: #ffffff;
    text: eval(tag("imu_acc_x"));
    font-size: 12;
    text-offset: 5;
}
