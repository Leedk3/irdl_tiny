canvas {
    fill-color: #0000f;
    text-color: #ffffff;
    error-color: #ffffff;
}

node[!imu_rot_z],
node[imu_rot_z != 0] {
    symbol-shape: square;
    symbol-stroke-width: 1.0;
    symbol-fill-color: #0000ff;
    symbol-stroke-color: #ffffff;
    text: eval(tag("imu_rot_z"));
    font-size: 12;
    text-offset: 5;
}
